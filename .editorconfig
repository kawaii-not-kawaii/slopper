root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 140

[*.{kt,kts}]
# Compose: @Composable functions are PascalCase by convention; tell ktlint to ignore them
# in `function-naming` rather than fighting community-wide Compose style.
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview

# `filename` requires single-top-level-declaration files to be named after the declaration.
# We have legacy single-declaration files (e.g. Color.kt holding `object StashColors`) where
# a rename would touch downstream imports. Disable the rule globally to keep ktlintCheck
# green on the existing tree; future modules can rename when convenient.
ktlint_standard_filename = disabled

# Property naming: route constants etc. use PascalCase across the codebase.
# Renaming would touch every navigation call site. Keep disabled for now;
# revisit during a future POLISH-scoped style pass.
ktlint_standard_property-naming = disabled
