# Copy this file to `keystore.properties` (NEVER check that one in) or set the
# corresponding STASH_KEYSTORE_* environment variables in CI.
#
# The release build type in app/build.gradle.kts reads these to sign the APK.
# Without either source, release builds fall back to the debug keystore
# (fine for personal sideload / smoke tests, NOT for Play Store distribution).

storeFile=../keystore.jks
storePassword=change_me
keyAlias=stash-release
keyPassword=change_me
