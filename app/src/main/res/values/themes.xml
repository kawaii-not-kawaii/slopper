<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- COMPLY-01 (per D-04): bar colors stripped — enableEdgeToEdge() handles
         tinting via windowLightStatusBar + content overlays. -->
    <!-- Base attributes for the system bars. Compose supplies the actual visuals. -->
    <style name="Theme.Stash" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- COMPLY-04 splash theme. Transitions to Theme.Stash after first
         composition (postSplashScreenTheme). per D-05. -->
    <style name="Theme.Stash.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.Stash</item>
    </style>
</resources>
